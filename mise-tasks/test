#!/usr/bin/env bash
#MISE description="Run plugin tests - link, install, and verify llama-cpp"
set -euo pipefail

mise plugin link --force llama-cpp .
mise cache clear
mise install llama-cpp@latest

output=$(mise exec "llama-cpp@latest" -- llama-cli --version 2>&1 || true)
echo "llama-cli output: $output"

if echo "$output" | grep -qi 'llama'; then
    echo "Tests passed"
else
    echo "Test failed: llama-cli not working"
    exit 1
fi
